---
import type { Sponsor } from "@/types/data";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

const sponsors = Object.values(
  import.meta.glob<Sponsor>("@/data/sponsors/*.json", {
    eager: true,
    import: "default",
  }),
);
---

<MainGridLayout title="赞助支持">
  <div class="space-y-6">
    <section class="card-base p-6 md:p-8 hero">
      <div class="flex items-start gap-4">
        <div class="hero-icon">
          <Icon name="material-symbols:favorite" class="text-[1.4rem]" />
        </div>

        <div class="flex-1">
          <div class="flex flex-wrap items-center gap-3 mb-3">
            <h1 class="text-2xl md:text-3xl font-bold text-black dark:text-white">
              赞助支持
            </h1>
            <span class="badge">感谢每一份喜欢</span>
          </div>

          <p class="hero-desc">
            如果你觉得这里的内容对你有一点点帮助，欢迎支持我的创作。
            无论是赞助、分享，还是留言互动，都会让我更有动力继续认真更新。
          </p>

          <p class="hero-sub">Ciallo～ (∠・ω&lt; )⌒★</p>
        </div>
      </div>
    </section>

    <section class="card-base p-6 md:p-8">
      <div class="section-head">
        <div>
          <h2 class="section-title">支持方式</h2>
          <p class="section-desc">不一定非要赞助，下面这些方式也很珍贵。</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
        <div class="mini-card">
          <div class="mini-title">
            <Icon name="material-symbols:share" class="text-[1.1rem] text-[var(--primary)]" />
            <span>分享推荐</span>
          </div>
          <p>把文章分享给更多朋友，让内容被更多人看到。</p>
        </div>

        <div class="mini-card">
          <div class="mini-title">
            <Icon name="material-symbols:comment" class="text-[1.1rem] text-[var(--primary)]" />
            <span>留言互动</span>
          </div>
          <p>在文章下方留下你的想法，这也是很好的支持。</p>
        </div>

        <div class="mini-card">
          <div class="mini-title">
            <Icon name="material-symbols:rss-feed" class="text-[1.1rem] text-[var(--primary)]" />
            <span>关注订阅</span>
          </div>
          <p>订阅 RSS 或关注更新，陪我把这个博客慢慢做下去。</p>
        </div>
      </div>
    </section>

    {sponsors.length > 0 && (
      <section class="card-base p-6 md:p-8">
        <div class="section-head">
          <div>
            <h2 class="section-title">赞助名单</h2>
            <p class="section-desc">感谢这些温柔又可爱的小伙伴。</p>
          </div>
          <span class="count">{sponsors.length} 位支持者</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-6">
          {sponsors.map((sponsor) => (
            <div class="sponsor-card">
              <div class="avatar">
                {sponsor.avatar ? (
                  <img src={sponsor.avatar} alt={`${sponsor.name}的头像`} loading="lazy" />
                ) : (
                  <Icon name="material-symbols:person" class="text-[1.2rem] text-black/35 dark:text-white/35" />
                )}
              </div>

              <div class="min-w-0 flex-1">
                <h3 class="name">{sponsor.name}</h3>
                <p class="date">{sponsor.date}</p>
              </div>

              <div class="amount">{sponsor.amount}</div>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</MainGridLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    right: -40px;
    bottom: -40px;
    width: 140px;
    height: 140px;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--primary) 18%, transparent) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-icon {
    width: 3rem;
    height: 3rem;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary);
    color: white;
    flex-shrink: 0;
  }

  .badge,
  .count {
    display: inline-flex;
    align-items: center;
    height: 1.9rem;
    padding: 0 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    color: var(--primary);
  }

  .hero-desc {
    line-height: 1.9;
    color: rgba(0, 0, 0, 0.65);
    max-width: 48rem;
  }

  .hero-sub {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    color: rgba(0, 0, 0, 0.48);
  }

  :global(.dark) .hero-desc,
  :global(.dark) .section-desc,
  :global(.dark) .mini-card p,
  :global(.dark) .date,
  :global(.dark) .hero-sub {
    color: rgba(255, 255, 255, 0.62);
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: black;
  }

  .section-desc {
    margin-top: 0.35rem;
    font-size: 0.92rem;
    color: rgba(0, 0, 0, 0.55);
  }

  :global(.dark) .section-title,
  :global(.dark) .name {
    color: white;
  }

  .mini-card,
  .sponsor-card {
    border-radius: 1rem;
    background: var(--card-bg);
    border: 1px solid rgba(0, 0, 0, 0.08);
    transition: all 0.2s ease;
  }

  :global(.dark) .mini-card,
  :global(.dark) .sponsor-card {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .mini-card {
    padding: 1rem;
  }

  .mini-card:hover,
  .sponsor-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--primary) 24%, transparent);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
  }

  .mini-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.55rem;
    font-weight: 700;
    color: black;
  }

  :global(.dark) .mini-title {
    color: white;
  }

  .mini-card p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.8;
    color: rgba(0, 0, 0, 0.58);
  }

  .sponsor-card {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1rem;
  }

  .avatar {
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 0.85rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.04);
    flex-shrink: 0;
  }

  :global(.dark) .avatar {
    background: rgba(255, 255, 255, 0.06);
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .name {
    font-size: 0.96rem;
    font-weight: 700;
    color: black;
    line-height: 1.4;
  }

  .date {
    margin-top: 0.2rem;
    font-size: 0.82rem;
    color: rgba(0, 0, 0, 0.5);
  }

  .amount {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--primary);
    flex-shrink: 0;
  }
</style>