---
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import BackToTop from "@components/control/BackToTop.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
} = Astro.props;

const { banner: bannerConfig, toc: tocConfig } = siteConfig;

const showBanner = bannerConfig.enable;
const showTOC = tocConfig.enable;
const hasBannerCredit = showBanner && bannerConfig.credit.enable;
const hasBannerLink = Boolean(bannerConfig.credit.url);

const mainPanelTop = showBanner
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";

const bannerWrapperStyle = `top: -${BANNER_HEIGHT_EXTEND}vh`;
const mainPanelStyle = `top: ${mainPanelTop}`;

const topRowClass =
	"z-50 pointer-events-none relative transition-all duration-700 max-w-[var(--page-width)] px-4 mx-auto";

const mainGridClass =
	"transition duration-700 w-full left-0 right-0 grid grid-cols-[17.5rem_auto] grid-rows-[auto_auto_auto] lg:grid-rows-[auto_1fr] mx-auto gap-4 px-4";

const bannerCreditClass = [
	"group onload-animation transition-all absolute flex justify-center items-center rounded-full px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9",
	{ "hover:pr-9 active:bg-black/80": hasBannerLink },
];

const tocWrapperClass = [
	"hidden lg:block transition absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] flex items-center",
	{ "toc-hide": showBanner },
];
---

<Layout
	title={title}
	banner={banner}
	description={description}
	lang={lang}
	setOGTypeArticle={setOGTypeArticle}
>
	<slot slot="head" name="head" />

	<div id="top-row" class={topRowClass}>
		<div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
			<Navbar />
		</div>
	</div>

	{showBanner && (
		<div
			id="banner-wrapper"
			class="absolute z-10 w-full transition duration-700 overflow-hidden"
			style={bannerWrapperStyle}
		>
			<ImageWrapper
				id="banner"
				alt="Banner image of the blog"
				class:list={["object-cover h-full transition duration-700 opacity-0 scale-105"]}
				src={bannerConfig.src}
				position={bannerConfig.position}
			/>
		</div>
	)}

	<div class="absolute w-full z-30 pointer-events-none" style={mainPanelStyle}>
		<div class="relative max-w-[var(--page-width)] mx-auto pointer-events-auto">
			<div id="main-grid" class={mainGridClass}>
				{hasBannerCredit && (
					<a
						href={bannerConfig.credit.url}
						id="banner-credit"
						target="_blank"
						rel="noopener"
						aria-label="Visit image source"
						class:list={bannerCreditClass}
					>
						<Icon
							class="text-white/75 text-[1.25rem] mr-1"
							name="material-symbols:copyright-outline-rounded"
						/>
						<div class="text-white/75 text-xs">{bannerConfig.credit.text}</div>
						<Icon
							class:list={[
								"transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
								{ "group-hover:opacity-100": hasBannerLink },
							]}
							name="fa6-solid:arrow-up-right-from-square"
						/>
					</a>
				)}

				<SideBar
					class="mb-4 row-start-2 col-span-2 lg:row-start-1 lg:col-start-1 lg:col-span-1 lg:max-w-[17.5rem] onload-animation"
					headings={headings}
				/>

				<main
					id="swup-container"
					class="transition-swup-fade row-start-1 col-span-2 lg:row-start-1 lg:col-start-2 lg:col-span-1 overflow-visible min-w-0"
				>
					<div id="content-wrapper" class="onload-animation">
						<slot />
					</div>
				</main>

				<div class="footer col-span-2 row-start-3 lg:col-span-1 lg:col-start-2 lg:row-start-2 onload-animation">
					<Footer />
				</div>
			</div>

			<BackToTop />
		</div>
	</div>

	<div class="absolute w-full z-0 hidden 2xl:block">
		<div class="relative max-w-[var(--page-width)] mx-auto">
			{showTOC ? (
				<div id="toc-wrapper" class:list={tocWrapperClass}>
					<div
						id="toc-inner-wrapper"
						class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar"
					>
						<div id="toc" class="w-full h-full transition-swup-fade">
							<div class="h-8 w-full"></div>
							<TOC headings={headings} />
							<div class="h-8 w-full"></div>
						</div>
					</div>
				</div>
			) : (
				<div id="toc"></div>
			)}
		</div>
	</div>
</Layout>