---
import { Icon } from "astro-icon/components";
import { profileConfig, siteConfig, umamiConfig } from "../../config";

const config = profileConfig;
const hasSingleLink = config.links.length === 1;
---

<div class="card-base border border-[var(--hairline)] p-4">
  <div class="flex flex-col items-center text-center">
    <!-- 头像 -->
    <div
      class="relative mb-3 h-20 w-20 overflow-hidden rounded-full ring-1 ring-black/5 transition dark:ring-white/10"
      style={`--theme-hue: ${siteConfig.themeColor.hue}`}
    >
      <img
        src={config.avatar}
        alt="Profile Image of the Author"
        class="h-full w-full object-cover transition duration-500"
      />
    </div>

    <!-- 名字 -->
    <div class="text-lg font-semibold leading-none text-[#171717] transition dark:text-white tracking-tight">
      {config.name}
    </div>

    <!-- 小分隔线 -->
    <div class="my-2 h-0.5 w-8 rounded-full bg-[#171717] dark:bg-white transition"></div>

    <!-- 简介 -->
    <p class="max-w-[18ch] text-xs leading-5 text-[#888888] transition dark:text-[#8a8f98]">
      {config.bio}
    </p>

    <!-- 社交按钮 -->
    <div class="mt-3 flex flex-wrap items-center justify-center gap-1.5">
      {hasSingleLink ? (
        <a
          rel="me"
          aria-label={config.links[0].name}
          href={config.links[0].url}
          target="_blank"
          class="btn-regular inline-flex h-8 items-center gap-1.5 rounded-full px-3 text-xs font-medium active:scale-95"
        >
          <Icon name={config.links[0].icon} class="text-[1rem]" />
          <span>{config.links[0].name}</span>
        </a>
      ) : (
        config.links.map((item) => (
          <a
            rel="me"
            aria-label={item.name}
            href={item.url}
            target="_blank"
            class="btn-regular inline-flex h-8 w-8 items-center justify-center rounded-full active:scale-95"
          >
            <Icon name={item.icon} class="text-[1rem]" />
          </a>
        ))
      )}
    </div>
  </div>

  <!-- 统计区 -->
  <div class="mt-3 grid grid-cols-2 gap-2 border-t border-[var(--hairline)] pt-3">
    <div class="rounded-lg bg-[var(--btn-regular-bg)] px-2.5 py-2 text-center">
      <div class="mb-0.5 flex items-center justify-center gap-1 text-[0.7rem] text-[#888888] dark:text-[#8a8f98]">
        <Icon name="material-symbols:visibility-outline" class="text-[0.85rem]" />
        <span>访问量</span>
      </div>
      <div
        id="site-views"
        class="text-base font-semibold tracking-tight text-[#171717] dark:text-white tabular-nums"
      >
        0
      </div>
    </div>

    <div class="rounded-lg bg-[var(--btn-regular-bg)] px-2.5 py-2 text-center">
      <div class="mb-0.5 flex items-center justify-center gap-1 text-[0.7rem] text-[#888888] dark:text-[#8a8f98]">
        <Icon name="material-symbols:person-outline" class="text-[0.85rem]" />
        <span>访客数</span>
      </div>
      <div
        id="site-visitors"
        class="text-base font-semibold tracking-tight text-[#171717] dark:text-white tabular-nums"
      >
        0
      </div>
    </div>
  </div>
</div>

<script define:vars={{ umamiConfig }}>
  function animateValue(el, start, end, duration) {
    let startTimestamp = null;

    const step = (timestamp) => {
      if (!startTimestamp) startTimestamp = timestamp;
      const progress = Math.min((timestamp - startTimestamp) / duration, 1);
      el.textContent = Math.floor(progress * (end - start) + start).toLocaleString();

      if (progress < 1) {
        window.requestAnimationFrame(step);
      } else {
        el.textContent = end.toLocaleString();
      }
    };

    window.requestAnimationFrame(step);
  }

  async function loadSiteStats() {
    if (!umamiConfig?.enable || typeof fetchUmamiStats !== "function") return;

    try {
      const statsData = await fetchUmamiStats(
        umamiConfig.baseUrl,
        umamiConfig.shareId,
        { timezone: umamiConfig.timezone }
      );

      const pageviews = Number(statsData?.pageviews || 0);
      const visitors = Number(statsData?.visitors || 0);

      const viewsElement = document.getElementById("site-views");
      const visitorsElement = document.getElementById("site-visitors");

      if (viewsElement) {
        const current = Number((viewsElement.textContent || "0").replace(/,/g, ""));
        if (current !== pageviews) {
          animateValue(viewsElement, current, pageviews, 800);
        }
      }

      if (visitorsElement) {
        const current = Number((visitorsElement.textContent || "0").replace(/,/g, ""));
        if (current !== visitors) {
          animateValue(visitorsElement, current, visitors, 800);
        }
      }
    } catch (error) {
      console.error("获取全站统计失败:", error);
    }
  }

  document.addEventListener("DOMContentLoaded", loadSiteStats);
  document.addEventListener("content:replace", loadSiteStats);
</script>
