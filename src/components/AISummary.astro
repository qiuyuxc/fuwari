---
import "../styles/ai-summary.css";
const { summary } = Astro.props;
---

<div id="ai-summary-wrapper" class="ai-summary-scope">
  <!-- 展开按钮移到外层，避免收起后一起被隐藏 -->
  <button
    id="ai-expand-btn"
    class="ai-floating-expand force-hide"
    type="button"
    aria-label="展开 AI 摘要"
  >
    <img width="18" height="18" src="/gemini-color.png" alt="ai" />
    <span>AI 摘要</span>
  </button>

  <div class="ai-summary-inner">
    <section
      id="ai-main-container"
      class="ai-main-container"
      aria-label="AI 摘要"
    >
      <div id="ai-track" class="ai-border-track" aria-hidden="true"></div>

      <div class="ai-card">
        <div class="ai-card-head">
          <div class="ai-card-title">
            <div class="ai-card-icon">
              <img width="22" height="22" src="/gemini-color.png" alt="ai" />
            </div>
            <div class="ai-card-title-text">
              <span class="ai-kicker">AI SUMMARY</span>
              <strong>AI 摘要</strong>
            </div>
          </div>

          <button
            id="ai-close-btn"
            class="ai-close-btn"
            type="button"
            aria-label="收起 AI 摘要"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>

        <div class="ai-card-body">
          <p
            id="ai-type-target"
            class="ai-summary-text"
            data-content={summary}
          ></p>
        </div>
      </div>
    </section>
  </div>
</div>

<script is:inline>
  (() => {
    const ZWSP = "\u200B";
    const STORAGE_KEY = "ai-collapsed";

    function initAI() {
      const wrapper = document.getElementById("ai-summary-wrapper");
      if (!wrapper) return;

      const main = document.getElementById("ai-main-container");
      const expandBtn = document.getElementById("ai-expand-btn");
      const textTarget = document.getElementById("ai-type-target");
      const track = document.getElementById("ai-track");
      const closeBtn = document.getElementById("ai-close-btn");

      if (!main || !expandBtn || !textTarget || !track || !closeBtn) return;

      const content = textTarget.getAttribute("data-content") || "";
      let rafId = null;
      let destroyed = false;

      function stopTyping() {
        if (rafId) {
          cancelAnimationFrame(rafId);
          rafId = null;
        }
      }

      function startTyping() {
        stopTyping();

        if (!content) {
          textTarget.textContent = "";
          track.style.opacity = "0";
          return;
        }

        let i = 0;
        let lastTime = 0;
        const interval = 18;

        function step(timestamp) {
          if (!lastTime) lastTime = timestamp;

          if (timestamp - lastTime >= interval) {
            i += Math.max(1, Math.floor(content.length / 120));
            textTarget.textContent = content.slice(0, i) || ZWSP;
            lastTime = timestamp;

            if (i < content.length) {
              rafId = requestAnimationFrame(step);
            } else {
              textTarget.textContent = content;
              track.style.opacity = "0";
              rafId = null;
            }
          } else {
            rafId = requestAnimationFrame(step);
          }
        }

        rafId = requestAnimationFrame(step);
      }

      function openSummary() {
        localStorage.setItem(STORAGE_KEY, "false");
        wrapper.classList.remove("is-collapsed");
        expandBtn.classList.add("force-hide");
        main.classList.remove("state-flying");
        textTarget.textContent = ZWSP;

        requestAnimationFrame(() => {
          track.style.opacity = "1";
          startTyping();
        });
      }

      function closeSummary() {
        localStorage.setItem(STORAGE_KEY, "true");
        stopTyping();
        track.style.opacity = "0";
        main.classList.add("state-flying");

        setTimeout(() => {
          if (destroyed) return;
          wrapper.classList.add("is-collapsed");
          expandBtn.classList.remove("force-hide");
          textTarget.textContent = ZWSP;
        }, 160);
      }

      closeBtn.onclick = (e) => {
        e.preventDefault();
        closeSummary();
      };

      expandBtn.onclick = (e) => {
        e.preventDefault();
        openSummary();
      };

      const isCollapsed = localStorage.getItem(STORAGE_KEY) === "true";

      if (isCollapsed) {
        wrapper.classList.add("is-collapsed");
        expandBtn.classList.remove("force-hide");
        textTarget.textContent = ZWSP;
        track.style.opacity = "0";
      } else {
        wrapper.classList.remove("is-collapsed");
        expandBtn.classList.add("force-hide");
        textTarget.textContent = ZWSP;

        setTimeout(() => {
          if (destroyed) return;
          track.style.opacity = "1";
          startTyping();
        }, 260);
      }

      window.addEventListener(
        "beforeunload",
        () => {
          destroyed = true;
          stopTyping();
        },
        { once: true }
      );
    }

    document.addEventListener("astro:page-load", initAI);
    if (document.readyState === "complete") {
      initAI();
    } else {
      window.addEventListener("load", initAI, { once: true });
    }
  })();
</script>