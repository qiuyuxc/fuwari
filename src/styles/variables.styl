/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

/* ponytail: rainbow kept for DisplaySettings hue slider compatibility */
rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 16px
  --content-delay 150ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

/* ═══════════════════════════════════════════════════════════════
   Vercel-Inspired Design System
   Canvas: #ffffff | Canvas-soft: #fafafa | Ink: #171717
   Link: #171717 | Primary CTA: #171717 (black ink)
   ═══════════════════════════════════════════════════════════════ */

define({
  /* ── Primary (light: black ink CTA / dark: white for visibility) ── */
  --primary: #171717 #ffffff
  --primary-hover: #333333 #e0e0e0
  --primary-focus: #171717 #ffffff
  --primary-inverse: #ffffff #171717

  /* ── Page & surface ladder ── */
  --page-bg: #fafafa #010102
  --card-bg: rgba(255, 255, 255, 0.75) #0f1011
  --card-bg-transparent: rgba(255, 255, 255, 0.8) rgba(15, 16, 17, 0.8)
  --surface-2: #f5f5f5 #141516
  --surface-3: #ebebeb #18191a
  --surface-4: #e0e0e0 #191a1b

  /* ── Text hierarchy ── */
  --deep-text: #171717 #f7f8f8
  --text-ink: #171717 #f7f8f8
  --text-muted: #4d4d4d #d0d6e0
  --text-subtle: #888888 #8a8f98
  --text-tertiary: #a1a1a1 #62666d

  /* ── Buttons ── */
  --btn-content: #171717 #ffffff
  --btn-regular-bg: #f5f5f5 #141516
  --btn-regular-bg-hover: #ebebeb #18191a
  --btn-regular-bg-active: #e0e0e0 #191a1b
  --btn-plain-bg-hover: rgba(0, 0, 0, 0.03) rgba(255, 255, 255, 0.04)
  --btn-plain-bg-active: rgba(0, 0, 0, 0.05) rgba(255, 255, 255, 0.06)
  --btn-card-bg-hover: rgba(0, 0, 0, 0.02) rgba(255, 255, 255, 0.03)
  --btn-card-bg-active: rgba(0, 0, 0, 0.04) rgba(255, 255, 255, 0.05)
  --enter-btn-bg: #f5f5f5 #141516
  --enter-btn-bg-hover: #ebebeb #18191a
  --enter-btn-bg-active: #e0e0e0 #191a1b

  /* ── Title & selection ── */
  --title-active: #171717 #ffffff
  --selection-bg: rgba(0, 112, 243, 0.12) rgba(94, 106, 210, 0.3)

  /* ── Borders ── */
  --line-divider: #ebebeb #23252a
  --line-color: #ebebeb #23252a
  --meta-divider: #a1a1a1 #34343a
  --hairline: #ebebeb #23252a
  --hairline-strong: #a1a1a1 #34343a
  --hairline-tertiary: #888888 #3e3e44

  /* ── Code blocks ── */
  --inline-code-bg: #f5f5f5 #141516
  --inline-code-color: #171717 #ffffff
  --codeblock-bg: #171717 #0f1011
  --codeblock-topbar-bg: #222222 #141516
  --codeblock-selection: rgba(0, 112, 243, 0.2)

  /* ── License block ── */
  --license-block-bg: #fafafa #0f1011

  /* ── Links ── */
  --link-underline: rgba(0, 0, 0, 0.4) rgba(255, 255, 255, 0.4)
  --link-hover: rgba(0, 112, 243, 0.08) rgba(94, 106, 210, 0.15)
  --link-active: rgba(0, 112, 243, 0.12) rgba(94, 106, 210, 0.2)

  /* ── Float panels ── */
  --float-panel-bg: rgba(255, 255, 255, 0.95) rgba(15, 16, 17, 0.95)
  --float-panel-bg-transparent: rgba(255, 255, 255, 0.85) rgba(15, 16, 17, 0.85)
  --float-panel-bg-opaque: #ffffff #0f1011

  /* ── Scrollbar ── */
  --scrollbar-bg-light: rgba(0, 0, 0, 0.15)
  --scrollbar-bg-hover-light: rgba(0, 0, 0, 0.25)
  --scrollbar-bg-active-light: rgba(0, 0, 0, 0.35)
  --scrollbar-bg-dark: rgba(255, 255, 255, 0.15)
  --scrollbar-bg-hover-dark: rgba(255, 255, 255, 0.25)
  --scrollbar-bg-active-dark: rgba(255, 255, 255, 0.35)
  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  /* ── Rainbow mode ── */
  --color-selection-bar: rainbow-light rainbow-dark

  /* ── Display icons ── */
  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  /* ── Admonitions ── */
  --admonitions-color-tip: #171717 #ffffff
  --admonitions-color-note: #171717 #ffffff
  --admonitions-color-important: #171717 #ffffff
  --admonitions-color-warning: #f5a623 #f5a623
  --admonitions-color-caution: #ee0000 #ee0000

  /* ── TOC ── */
  --toc-badge-bg: #f5f5f5 #141516
  --toc-btn-hover: rgba(0, 0, 0, 0.03) rgba(255, 255, 255, 0.04)
  --toc-btn-active: rgba(0, 0, 0, 0.05) rgba(255, 255, 255, 0.06)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: #171717 #ffffff
})
